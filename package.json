{
  "name": "@bjalon/form-runtime",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Runtime React pour compiler, afficher et collecter des questionnaires YAML.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bjalon/qastia-questionnaire.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/form-runtime.js",
  "module": "./dist/form-runtime.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/form-runtime.js"
    },
    "./compiler": {
      "types": "./dist/types/compiler.d.ts",
      "import": "./dist/compiler.js"
    },
    "./runtime": {
      "types": "./dist/types/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./runner": {
      "types": "./dist/types/runner.d.ts",
      "import": "./dist/runner.js"
    },
    "./preview": {
      "types": "./dist/types/preview.d.ts",
      "import": "./dist/preview.js"
    },
    "./designer": {
      "types": "./dist/types/designer.d.ts",
      "import": "./dist/designer.js"
    },
    "./styles.css": "./dist/form-runtime.css"
  },
  "sideEffects": [
    "*.css",
    "./dist/form-runtime.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:example": "vite build --config vite.example.config.ts",
    "dev:example": "vite --config vite.example.config.ts --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "typescript": "^5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.2"
  }
}
